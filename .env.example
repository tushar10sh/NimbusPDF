# Copy to .env and fill in values

# OIDC provider (leave blank to disable auth)
OIDC_ISSUER_URL=
OIDC_CLIENT_ID=
OIDC_CLIENT_SECRET=
# Must include localhost redirect for self-hosted Docker deployments
OIDC_REDIRECT_URI=http://localhost:3000/auth/callback

# App secret for signing session cookies
SESSION_SECRET=change-me-to-a-random-32-char-string

# Google Drive OAuth (optional, for authenticated users)
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=
GDRIVE_REDIRECT_URI=http://localhost:3000/api/auth/gdrive/callback

# Anonymous session TTL in hours (default: 24)
ANONYMOUS_SESSION_TTL_HOURS=24
